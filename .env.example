# Great.Cards MCP Server Configuration

# Required
PARTNER_API_KEY=your_partner_api_key_here

# API endpoints (defaults to UAT)
PARTNER_TOKEN_URL=https://uat-platform.bankkaro.com/partner/token
PARTNER_BASE_URL=https://uat-platform.bankkaro.com/partner

# Transport: "stdio" (default, for Claude Desktop/Code) or "sse" (for remote hosting)
MCP_TRANSPORT=stdio

# SSE mode settings
PORT=3100
CORS_ORIGIN=*

# Cache TTL in hours (default: 168 = 7 days)
CACHE_TTL_HOURS=168

# Per-client API keys (JSON string) — optional
# If not set, auth is disabled and PARTNER_API_KEY is used for all requests
# CLIENT_KEYS={"gc_live_abc123":{"name":"Acme Bot","partnerApiKey":"your_key","rateLimit":30,"enabled":true}}
